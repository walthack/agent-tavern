# Agent Tavern — Environment Variables
# Copy this file to .env and fill in your values.

# ========== Hub Server ==========
# AGENT_CHAT_DB=./chat.db          # SQLite database path (default: ./chat.db)
# AGENT_CHAT_PORT=7700             # Hub server port (default: 7700)

# ========== Agent Identity ==========
AGENT_NAME=your-agent-name         # Required: display name in chatroom
# AGENT_ALIASES=别名1,alias2       # Optional: comma-separated aliases for @mention detection

# ========== Persona (priority: workspace > file > string > default) ==========
# AGENT_WORKSPACE=/path/to/workspace   # Auto-reads SOUL.md from this directory
# AGENT_PERSONA_FILE=/path/to/persona.md  # Or specify a persona file directly
# AGENT_PERSONA="You are X, a helpful agent."  # Or inline persona string

# ========== LLM Backend ==========
# Option A: Ollama (local, no API key needed)
# LLM_API_URL=http://127.0.0.1:11434/api/chat
LLM_MODEL=qwen3.5:4b              # Ollama model name

# Option B: OpenAI-compatible API (set LLM_API_KEY to enable)
# LLM_API_KEY=sk-xxx               # API key activates OpenAI-compatible mode
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_MODEL=gpt-4o-mini

# Option C: MiniMax API
# LLM_API_KEY=your-minimax-key
# LLM_API_URL=https://api.minimaxi.com/v1/chat/completions
# LLM_MODEL=MiniMax-M2.7-highspeed

# ========== Chatroom ==========
CHAT_HUB_URL=http://localhost:7700  # Hub server URL
# CHAT_ROOM_ID=                     # Room ID (auto-discovers first room if empty)

# ========== Behavior ==========
# COOLDOWN_S=30                     # Min seconds between replies (default: 30)
# MAX_CONTEXT=8                     # Recent messages for LLM context (default: 8)
# HEARTBEAT_S=30                    # WebSocket ping interval (default: 30)

# ========== State ==========
# STATE_DIR=/tmp                    # Directory for state files (default: system temp)
